  {
    "id": "demand",
    "name": "Heating & cooling demand",
    "default_dataset": "merra2",
    "datasets": [
      {
        "id": "merra2",
        "name": "MERRA-2 (global)",
        "daterange": [
          "2019-01-01",
          "2019-12-31"
        ],
        "bounds": [
          90,
          -180,
          -90,
          180
        ]
      }
    ],
    "license_url": "https://creativecommons.org/licenses/by-nc/4.0/",
    "license_name": "Creative Commons Attribution-NonCommercial",
    "citation_url": "https://doi.org/10.1038/s41560-023-01341-5",
    "citation_name": "Staffell et al. (2023)",
    "max_daterange": "P1Y",
    "version": 1.0,
    "fields": [
      {
        "id": "heating_threshold",
        "name": "Heating threshold (\u00b0C)",
        "help": "Temperature below which heating is required. Context: 11 to 17 degrees is the typical range seen across OECD countries.",
        "type": "float",
        "min": -50,
        "max": 50,
        "default": 14,
        "optional": true
      },
      {
        "id": "cooling_threshold",
        "name": "Cooling threshold (\u00b0C)",
        "help": "Temperature above which cooling is required. Context: 17 to 23 degrees is the typical range seen across OECD countries.",
        "type": "float",
        "min": -50,
        "max": 50,
        "default": 20,
        "optional": true
      },
      {
        "id": "base_power",
        "name": "Base power (kW)",
        "help": "The base level of demand when it is neither hot nor cold. Context: if simulating electricity or gas demand, this value represents 'other' uses that do not depend on outdoor temperature (e.g. cooking, water heating, lighting, appliances).",
        "type": "float",
        "min": 0,
        "default": 0,
        "optional": true
      },
      {
        "id": "heating_power",
        "name": "Heating power (kW/\u00b0C)",
        "help": "The additional demand for heat as temperature falls below the heating threshold. This will scale with building size, its thermal performance, heating system efficiency, etc. Context: 25 W/\u00b0C is a typical value per person for electricity demand, and 100 W/\u00b0C per person is typical for gas demand.",
        "type": "float",
        "min": 0,
        "default": 0.3,
        "optional": true
      },
      {
        "id": "cooling_power",
        "name": "Cooling power (kW/\u00b0C)",
        "help": "The additional demand for cool as temperature rises above the cooling threshold. This will scale with building size, its thermal performance, HVAC efficiency, etc. Context: 50 W/\u00b0C is a typical value per person for electricity demand.",
        "type": "float",
        "min": 0,
        "default": 0.15,
        "optional": true
      },
      {
        "id": "smoothing",
        "name": "Smoothing (days\u207b\u00b9)",
        "help": "This represents the building's thermal inertia: the influence that temperatures on the previous two days have on the current temperature index. Higher values imply heavier construction and better insulation. Context: 0.20 to 0.80 is the typical range seen across OECD countries.",
        "type": "float",
        "min": 0,
        "max": 1,
        "default": 0.5,
        "optional": true
      },
      {
        "id": "solar_gains",
        "name": "Solar gains (\u00b0C per W/m\u00b2)",
        "help": "This represents solar gains in the building: the influence that greater sunshine has on increasing perceived temperature. Higher values imply larger windows allowing sunlight in. Context: 0.004 to 0.020 is the typical range seen across OECD countries.",
        "type": "float",
        "min": 0,
        "max": 0.1,
        "default": 0.012,
        "optional": true
      },
      {
        "id": "wind_chill",
        "name": "Wind chill (\u00b0C per m/s)",
        "help": "This represents wind chill in the building: the influence that greater wind speed has on reducing perceived temperature. Larger (more negative) values imply lower air tightness (more leaky). Context: -0.05 to -0.35 is the typical range seen across OECD countries.",
        "type": "float",
        "min": -1.5,
        "max": 0,
        "default": -0.2,
        "optional": true
      },
      {
        "id": "humidity_discomfort",
        "name": "Humidity discomfort (\u00b0C per g/kg)",
        "help": "This represents the added discomfort from humidity: the influence that greater humidity has on moving perceived temperature further from the desired level. Larger values imply greater discomfort during humid weather. Context: 0.00 to 0.10 is the typical range seen across OECD countries.",
        "type": "float",
        "min": 0,
        "max": 0.5,
        "default": 0.05,
        "optional": true
      },
      {
        "id": "use_diurnal_profile",
        "name": "Use diurnal profile",
        "help": "Should we use our global average empirical profile for the diurnal demand when upsampling from daily to hourly (i.e. when in the day people heat & cool)?",
        "type": "boolean",
        "default": true,
        "optional": true
      }
    ]
  },
  {
    "id": "weather",
    "name": "Weather",
    "default_dataset": "merra2",
    "datasets": [
      {
        "id": "merra2",
        "name": "MERRA-2 (global)",
        "daterange": [
          "2019-01-01",
          "2019-12-31"
        ],
        "bounds": [
          80,
          -180,
          -80,
          180
        ]
      }
    ],
    "license_url": "https://science.nasa.gov/earth-science/earth-science-data/data-information-policy",
    "license_name": "NASA Data Information Policy",
    "citation_url": "https://www.renewables.ninja/",
    "citation_name": "www.renewables.ninja and Gelaro et al. (2017), doi: 10.1175/JCLI-D-16-0758.1",
    "max_daterange": "P1Y",
    "version": 1.0,
    "fields": [
      {
        "id": "var_t2m",
        "name": "Air temperature (\u00b0C)",
        "help": "Air temperature at 2 meters above ground. T2M variable in MERRA-2, converted from K.",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_prectotland",
        "name": "Precipitation (mm / hour)",
        "help": "Total bias-corrected precipitation, over land only. PRECTOTLAND variable in MERRA-2, converted from kg m\u207b\u00b2 s\u207b\u00b9",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_precsnoland",
        "name": "Snowfall (mm / hour)",
        "help": "Total bias-corrected precipitation in the form of snow, over land only. PRECSNOLAND variable in MERRA-2, converted from kg m\u207b\u00b2 s\u207b\u00b9",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_snomas",
        "name": "Snow mass (kg / m\u00b2)",
        "help": "Amount of snow per land area. SNOMAS variable in MERRA-2, in native units.",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_rhoa",
        "name": "Air density (kg / m\u00b3)",
        "help": "Air density at ground level. RHOA variable in MERRA-2, in native units.",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_swgdn",
        "name": "Ground-level solar irradiance (W / m\u00b2)",
        "help": "Surface-level incident shortwave radiation flux, considering cloud cover and aerosols. SWGDN variable in MERRA-2, in native units. Note, MERRA-2 uses the mean annual climate for aerosols, rather than time-varying quantity.",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_swtdn",
        "name": "Top of atmosphere solar irradiance (W / m\u00b2)",
        "help": "Top of atmosphere incident shortwave radiation flux, before cloud cover and aerosol influences. SWTDN variable in MERRA-2, in native units.",
        "type": "boolean",
        "default": false,
        "optional": true
      },
      {
        "id": "var_cldtot",
        "name": "Cloud cover fraction",
        "help": "Fraction of cloud cover, averaged over grid cell and summed over all height above ground. CLDTOT variable in MERRA-2, in native units (a [0, 1] scale).",
        "type": "boolean",
        "default": false,
        "optional": true
      }
    ]
  }
]