[
  {
    "id": "pv",
    "name": "Solar photovoltaic power (PV)",
    "default_dataset": "merra2",
    "dataset_help": "MERRA has global coverage, while CM-SAF covers only Europe but with higher data quality.",
    "datasets": [
      {
        "id": "merra2",
        "name": "MERRA-2 (global)",
        "daterange": [
          "2019-01-01",
          "2019-12-31"
        ],
        "bounds": [
          90,
          -180,
          -90,
          180
        ]
      },
      {
        "id": "sarah",
        "name": "CM-SAF SARAH (Europe)",
        "daterange": [
          "2015-01-01",
          "2015-12-31"
        ],
        "bounds": [
          65,
          -11,
          24,
          44
        ]
      }
    ],
    "license_url": "https://creativecommons.org/licenses/by-nc/4.0/",
    "license_name": "Creative Commons Attribution-NonCommercial",
    "citation_url": "https://doi.org/10.1016/j.energy.2016.08.060",
    "citation_name": "Pfenninger and Staffell (2016)",
    "max_daterange": "P1Y",
    "version": "1.4 (gsee f9b6961)",
    "fields": [
      {
        "id": "capacity",
        "name": "Capacity (kW)",
        "help": "Maximum AC electrical power that the system is capable of generating (in kW).",
        "type": "float",
        "min": 0,
        "default": 1
      },
      {
        "id": "system_loss",
        "name": "System loss (fraction)",
        "help": "The combined losses from all system components (e.g. inverter, tracking system), relative to instantaneous output.",
        "type": "float",
        "min": 0,
        "max": 1,
        "default": 0.1
      },
      {
        "id": "tracking",
        "name": "Tracking",
        "type": "dropdown",
        "dropdown_type": "integer",
        "options": [
          {
            "value": 0,
            "label": "None"
          },
          {
            "value": 1,
            "label": "1-axis (azimuth)"
          },
          {
            "value": 2,
            "label": "2-axis (tilt & azimuth)"
          }
        ],
        "default": 0
      },
      {
        "id": "tilt",
        "name": "Tilt (\u00b0)",
        "help": "How far the panel is inclined from the horizontal, in degrees. A tilt of 0\u00b0 is a panel facing directly upwards, 90\u00b0 is a panel installed vertically, facing sideways.",
        "type": "integer",
        "min": 0,
        "max": 90,
        "default": 35
      },
      {
        "id": "azim",
        "name": "Azimuth (\u00b0)",
        "help": "Compass direction the panel is facing (clockwise). An azimuth angle of 180 degrees means poleward facing, so for latitudes >=0 is interpreted as southwards facing, else northwards facing.",
        "type": "integer",
        "min": 0,
        "max": 360,
        "default": 180
      },
      {
        "id": "raw",
        "name": "Include raw data",
        "help": "Tick this box to include additional columns with the underlying weather data used in the model, rather than just the model output itself. Raw weather data is included in the downloadable output file but not visualized in the web application.",
        "type": "boolean",
        "default": false,
        "optional": true
      }
    ]
  },
